  6. const myNumbers = [1, 2, 3, 7, 9];

console.log(myNumbers[3]);  -> quarto elemento: 7
console.log(myNumbers[1]);  -> secondo elemento: 2

  7. cicli: 
1. for classico
for (let i = 0; i < 5; i++) {
  console.log(i);
}

 2. while
let i = 0;
while (i < 5) {
  console.log(i);
  i++;
}

3. do...while (esegue almeno una volta)
let j = 0;
do {
  console.log(j);
  j++;
} while (j < 5);

4. for...of (sui valori di un array)
for (const num of myNumbers) {
  console.log(num);
}

5. for...in (sulle chiavi/indici)
for (const indice in myNumbers) {
  console.log(indice);
}
